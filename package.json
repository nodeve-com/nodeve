{
  "name": "@nodeve/root",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "prepare": "lefthook install || true",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r --if-present clean",
    "release": "pnpm build && changeset publish",
    "check": "nodeve-check && eslint .",
    "check:gate": "lefthook run pre-commit"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/compat": "catalog:",
    "@eslint/js": "catalog:",
    "@nodeve/checks": "workspace:*",
    "@nodeve/config": "workspace:*",
    "date-fns": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "globals": "catalog:",
    "prettier": "^3.9.5",
    "remeda-humps": "catalog:",
    "typescript": "^6.0.3",
    "typescript-eslint": "catalog:"
  }
}
