{
  "$defs": {
    "archetype": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "broader": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "code": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{8}$",
      "type": "string"
    },
    "column": {
      "additionalProperties": false,
      "properties": {
        "references": {
          "$ref": "#/$defs/references"
        }
      },
      "type": "object"
    },
    "description": {
      "additionalProperties": false,
      "properties": {
        "en": {
          "minLength": 3,
          "type": "string"
        },
        "pt": {
          "minLength": 3,
          "type": "string"
        }
      },
      "type": "object"
    },
    "id": {
      "minLength": 1,
      "type": "string"
    },
    "identity": {
      "additionalProperties": false,
      "properties": {
        "archetype": {
          "$ref": "#/$defs/archetype"
        },
        "broader": {
          "$ref": "#/$defs/broader"
        },
        "code": {
          "$ref": "#/$defs/code"
        },
        "id": {
          "$ref": "#/$defs/id"
        },
        "iri_template": {
          "$ref": "#/$defs/iri_template"
        },
        "slug": {
          "$ref": "#/$defs/slug"
        },
        "slug_qualified": {
          "$ref": "#/$defs/slug_qualified"
        },
        "symbol": {
          "$ref": "#/$defs/symbol"
        },
        "url": {
          "$ref": "#/$defs/url"
        }
      },
      "type": "object"
    },
    "iri_template": {
      "minLength": 1,
      "type": "string"
    },
    "match": {
      "enum": [
        "exact",
        "close",
        "broad",
        "narrow",
        "related"
      ]
    },
    "measurand": {
      "additionalProperties": false,
      "properties": {
        "accumulation": {
          "enum": [
            "cumulative",
            "cumulative_monotonic",
            "instantaneous"
          ],
          "type": "string"
        },
        "si_unit": {
          "$ref": "#/$defs/si_unit"
        },
        "unit": {
          "$ref": "#/$defs/unit"
        }
      },
      "type": "object"
    },
    "references": {
      "minLength": 1,
      "type": "string"
    },
    "refs": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "match": {
            "$ref": "#/$defs/match"
          },
          "registry_id": {
            "$ref": "#/$defs/registry_id"
          },
          "term": {
            "$ref": "#/$defs/term"
          }
        },
        "required": [
          "match",
          "registry_id",
          "term"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "registry_id": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "si_unit": {
      "type": "string"
    },
    "slug": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "slug_qualified": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "symbol": {
      "minLength": 1,
      "type": "string"
    },
    "term": {
      "minLength": 1,
      "type": "string"
    },
    "title": {
      "additionalProperties": false,
      "properties": {
        "en": {
          "minLength": 3,
          "type": "string"
        },
        "pt": {
          "minLength": 3,
          "type": "string"
        }
      },
      "type": "object"
    },
    "unit": {
      "minLength": 1,
      "type": "string"
    },
    "url": {
      "minLength": 1,
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "column": {
      "$ref": "#/$defs/column"
    },
    "description": {
      "$ref": "#/$defs/description"
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "measurand": {
      "$ref": "#/$defs/measurand"
    },
    "refs": {
      "$ref": "#/$defs/refs"
    },
    "title": {
      "$ref": "#/$defs/title"
    }
  },
  "type": "object"
}
