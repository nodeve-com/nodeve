{
  "description": {
    "en": "A PV array installation (location, inverter, per-string wiring/orientation)."
  },
  "prop": {
    "location": {
      "$ref": "../features/location.json",
      "description": {
        "en": "A site's geographic point (WGS 84 latitude / longitude / altitude above sea level).",
        "pt": "O ponto geográfico de um site (latitude / longitude / altitude acima do nível do mar, WGS 84)."
      },
      "title": {
        "en": "Location",
        "pt": "Local"
      }
    },
    "pv_strings": {
      "array": {
        "prop": {
          "active": {
            "$ref": "../property/active.json",
            "description": {
              "en": "Whether this member is currently in service. `false` keeps the record (wiring still exists) while excluding it from derived output."
            },
            "schema": {
              "required": true,
              "type": "boolean"
            },
            "title": {
              "en": "Active",
              "pt": "Ativo"
            }
          },
          "azimuth": {
            "$ref": "../property/azimuth.json",
            "description": {
              "en": "Plane orientation as compass degrees, 0° = N."
            },
            "schema": {
              "required": true,
              "type": "number"
            },
            "title": {
              "en": "Azimuth",
              "pt": "Azimute"
            }
          },
          "catalog_item": {
            "$ref": "../property/catalog_item.json",
            "schema": {
              "additionalProperties": false,
              "properties": {
                "archetype": {
                  "minLength": 1,
                  "type": "string"
                },
                "slug": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": true,
              "type": "object"
            },
            "title": {
              "en": "Catalog item",
              "pt": "Item de catálogo"
            }
          },
          "ordinal": {
            "$ref": "../property/ordinal.json",
            "description": {
              "en": "1-based position of one member in a repeated feature's list (string 1, string 2) — the stable join key a site and its derived config agree on."
            },
            "schema": {
              "exclusiveMinimum": 0,
              "required": true,
              "type": "integer"
            },
            "title": {
              "en": "Ordinal",
              "pt": "Ordinal"
            }
          },
          "series_count": {
            "$ref": "../property/series_count.json",
            "description": {
              "en": "Number of panels wired in series on one MPPT input (install fact, never a datasheet fact)."
            },
            "schema": {
              "exclusiveMinimum": 0,
              "required": true,
              "type": "integer"
            },
            "title": {
              "en": "Series count"
            }
          },
          "tilt": {
            "$ref": "../property/tilt.json",
            "description": {
              "en": "Plane tilt in degrees from horizontal."
            },
            "schema": {
              "required": true,
              "type": "number"
            },
            "title": {
              "en": "Tilt",
              "pt": "Inclinação"
            }
          },
          "voc_eff": {
            "$ref": "../property/voc_eff.json",
            "description": {
              "en": "As-deployed string open-circuit voltage, fitted from measured data. Omit until fitted; spec fallback is panel dc.voltage open_circuit-band nominal × series_count."
            },
            "schema": {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            "title": {
              "en": "Effective open-circuit voltage"
            }
          }
        }
      },
      "schema": {
        "minItems": 1,
        "required": true
      },
      "title": {
        "en": "PV strings",
        "pt": "Strings fotovoltaicas"
      }
    }
  },
  "title": {
    "en": "Solar array",
    "pt": "Matriz solar"
  }
}
