{
  "$defs": {
    "address": {
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "addressing": {
      "additionalProperties": false,
      "properties": {
        "password": {
          "$ref": "#/$defs/password"
        },
        "wifi_ssid": {
          "$ref": "#/$defs/wifi_ssid"
        }
      },
      "type": "object"
    },
    "archetype": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "broader": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "catalog_item": {
      "additionalProperties": false,
      "properties": {
        "archetype": {
          "minLength": 1,
          "type": "string"
        },
        "slug": {
          "minLength": 1,
          "type": "string"
        }
      },
      "type": "object"
    },
    "code": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{8}$",
      "type": "string"
    },
    "connect_timeout_ms": {
      "exclusiveMinimum": 0,
      "type": "integer"
    },
    "description": {
      "additionalProperties": false,
      "properties": {
        "en": {
          "minLength": 3,
          "type": "string"
        },
        "pt": {
          "minLength": 3,
          "type": "string"
        }
      },
      "type": "object"
    },
    "emit": {
      "additionalProperties": false,
      "properties": {
        "format": {
          "$ref": "#/$defs/format"
        },
        "publish": {
          "$ref": "#/$defs/publish"
        },
        "topic_prefix": {
          "$ref": "#/$defs/topic_prefix"
        },
        "update_interval_ms": {
          "$ref": "#/$defs/update_interval_ms"
        }
      },
      "type": "object"
    },
    "endpoint": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": [
              "service_protocol"
            ]
          },
          "then": {
            "properties": {
              "transport_protocol": {
                "const": "tcp"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "transport_protocol": {
                "const": "tcp"
              }
            },
            "required": [
              "transport_protocol"
            ]
          },
          "then": {
            "required": [
              "connect_timeout_ms",
              "reconnect_period_ms"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transport_protocol": {
                "const": "udp"
              }
            },
            "required": [
              "transport_protocol"
            ]
          },
          "then": {
            "properties": {
              "connect_timeout_ms": false,
              "reconnect_period_ms": false
            }
          }
        }
      ],
      "properties": {
        "connect_timeout_ms": {
          "$ref": "#/$defs/connect_timeout_ms"
        },
        "host": {
          "$ref": "#/$defs/host"
        },
        "pathname": {
          "$ref": "#/$defs/pathname"
        },
        "port": {
          "$ref": "#/$defs/port"
        },
        "reconnect_period_ms": {
          "$ref": "#/$defs/reconnect_period_ms"
        },
        "service_protocol": {
          "enum": [
            "mqtt",
            "mqtts",
            "http",
            "https",
            "ws",
            "wss"
          ],
          "type": "string"
        },
        "transport_protocol": {
          "enum": [
            "tcp",
            "udp"
          ],
          "type": "string"
        },
        "version": {
          "$ref": "#/$defs/version"
        }
      },
      "type": "object"
    },
    "format": {
      "enum": [
        "grouped",
        "per_value"
      ],
      "type": "string"
    },
    "host": {
      "minLength": 1,
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "type": "string"
    },
    "identity": {
      "additionalProperties": false,
      "properties": {
        "archetype": {
          "$ref": "#/$defs/archetype"
        },
        "broader": {
          "$ref": "#/$defs/broader"
        },
        "code": {
          "$ref": "#/$defs/code"
        },
        "id": {
          "$ref": "#/$defs/id"
        },
        "iri_template": {
          "$ref": "#/$defs/iri_template"
        },
        "slug": {
          "$ref": "#/$defs/slug"
        },
        "slug_qualified": {
          "$ref": "#/$defs/slug_qualified"
        },
        "symbol": {
          "$ref": "#/$defs/symbol"
        },
        "url": {
          "$ref": "#/$defs/url"
        }
      },
      "type": "object"
    },
    "ingest": {
      "additionalProperties": false,
      "properties": {
        "catalog_item": {
          "$ref": "#/$defs/catalog_item"
        },
        "ingest_kind": {
          "enum": [
            "modbus_tap"
          ],
          "type": "string"
        },
        "platform": {
          "enum": [
            "esphome",
            "farana",
            "telegraf"
          ],
          "type": "string"
        },
        "service_id": {
          "$ref": "#/$defs/service_id"
        }
      },
      "type": "object"
    },
    "iri_template": {
      "minLength": 1,
      "type": "string"
    },
    "match": {
      "enum": [
        "exact",
        "close",
        "broad",
        "narrow",
        "related"
      ]
    },
    "modbus_tap_window": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "address": {
            "$ref": "#/$defs/address"
          },
          "name": {
            "$ref": "#/$defs/name"
          },
          "observed_interval_ms": {
            "$ref": "#/$defs/observed_interval_ms"
          },
          "register_type": {
            "$ref": "#/$defs/register_type"
          },
          "retain": {
            "$ref": "#/$defs/retain"
          }
        },
        "required": [
          "address",
          "name"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "name": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "observed_interval_ms": {
      "minimum": 1,
      "type": "integer"
    },
    "password": {
      "minLength": 1,
      "type": "string"
    },
    "pathname": {
      "minLength": 1,
      "type": "string"
    },
    "port": {
      "maximum": 65535,
      "minimum": 1,
      "type": "integer"
    },
    "publish": {
      "enum": [
        "changed",
        "always"
      ],
      "type": "string"
    },
    "reconnect_period_ms": {
      "exclusiveMinimum": 0,
      "type": "integer"
    },
    "refs": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "match": {
            "$ref": "#/$defs/match"
          },
          "registry_id": {
            "$ref": "#/$defs/registry_id"
          },
          "term": {
            "$ref": "#/$defs/term"
          }
        },
        "required": [
          "match",
          "registry_id",
          "term"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "register_type": {
      "enum": [
        "holding",
        "input"
      ],
      "type": "string"
    },
    "registry_id": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "retain": {
      "type": "boolean"
    },
    "service_id": {
      "minLength": 1,
      "type": "string"
    },
    "slug": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "slug_qualified": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "symbol": {
      "minLength": 1,
      "type": "string"
    },
    "term": {
      "minLength": 1,
      "type": "string"
    },
    "title": {
      "additionalProperties": false,
      "properties": {
        "en": {
          "minLength": 3,
          "type": "string"
        },
        "pt": {
          "minLength": 3,
          "type": "string"
        }
      },
      "type": "object"
    },
    "topic_prefix": {
      "minLength": 1,
      "type": "string"
    },
    "update_interval_ms": {
      "exclusiveMinimum": 0,
      "type": "integer"
    },
    "url": {
      "minLength": 1,
      "type": "string"
    },
    "version": {
      "minLength": 1,
      "type": "string"
    },
    "wifi_ssid": {
      "maxLength": 32,
      "minLength": 1,
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "addressing": {
      "$ref": "#/$defs/addressing"
    },
    "description": {
      "$ref": "#/$defs/description"
    },
    "emit": {
      "$ref": "#/$defs/emit"
    },
    "endpoint": {
      "$ref": "#/$defs/endpoint"
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "ingest": {
      "$ref": "#/$defs/ingest"
    },
    "modbus_tap_window": {
      "$ref": "#/$defs/modbus_tap_window"
    },
    "refs": {
      "$ref": "#/$defs/refs"
    },
    "title": {
      "$ref": "#/$defs/title"
    }
  },
  "type": "object"
}
