{
  "$defs": {
    "archetype": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "broader": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "code": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{8}$",
      "type": "string"
    },
    "description": {
      "additionalProperties": false,
      "properties": {
        "en": {
          "minLength": 3,
          "type": "string"
        },
        "pt": {
          "minLength": 3,
          "type": "string"
        }
      },
      "type": "object"
    },
    "duplex": {
      "enum": [
        "half",
        "full"
      ],
      "type": "string"
    },
    "fqdn": {
      "maxLength": 253,
      "minLength": 1,
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "type": "string"
    },
    "identity": {
      "additionalProperties": false,
      "properties": {
        "archetype": {
          "$ref": "#/$defs/archetype"
        },
        "broader": {
          "$ref": "#/$defs/broader"
        },
        "code": {
          "$ref": "#/$defs/code"
        },
        "id": {
          "$ref": "#/$defs/id"
        },
        "iri_template": {
          "$ref": "#/$defs/iri_template"
        },
        "slug": {
          "$ref": "#/$defs/slug"
        },
        "slug_qualified": {
          "$ref": "#/$defs/slug_qualified"
        },
        "symbol": {
          "$ref": "#/$defs/symbol"
        },
        "url": {
          "$ref": "#/$defs/url"
        }
      },
      "type": "object"
    },
    "ip_address": {
      "minLength": 1,
      "type": "string"
    },
    "ip_addresses": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "description": {
            "$ref": "#/$defs/description"
          },
          "identity": {
            "$ref": "#/$defs/identity"
          },
          "ip_binding": {
            "$ref": "#/$defs/ip_binding"
          },
          "refs": {
            "$ref": "#/$defs/refs"
          },
          "title": {
            "$ref": "#/$defs/title"
          }
        },
        "type": "object"
      },
      "type": "array"
    },
    "ip_binding": {
      "additionalProperties": false,
      "properties": {
        "fqdn": {
          "$ref": "#/$defs/fqdn"
        },
        "ip_address": {
          "$ref": "#/$defs/ip_address"
        },
        "ip_family": {
          "enum": [
            "ipv4",
            "ipv6"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "iri_template": {
      "minLength": 1,
      "type": "string"
    },
    "link_speed": {
      "minimum": 1,
      "type": "integer"
    },
    "mac_address": {
      "pattern": "^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$",
      "type": "string"
    },
    "match": {
      "enum": [
        "exact",
        "close",
        "broad",
        "narrow",
        "related"
      ]
    },
    "mtu": {
      "maximum": 65535,
      "minimum": 68,
      "type": "integer"
    },
    "network_link": {
      "additionalProperties": false,
      "properties": {
        "duplex": {
          "$ref": "#/$defs/duplex"
        },
        "interface_type": {
          "enum": [
            "async_serial",
            "can",
            "ethernet_csmacd",
            "ieee80211",
            "usb"
          ],
          "type": "string"
        },
        "link_speed": {
          "$ref": "#/$defs/link_speed"
        },
        "mac_address": {
          "$ref": "#/$defs/mac_address"
        },
        "mtu": {
          "$ref": "#/$defs/mtu"
        }
      },
      "type": "object"
    },
    "refs": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "match": {
            "$ref": "#/$defs/match"
          },
          "registry_id": {
            "$ref": "#/$defs/registry_id"
          },
          "term": {
            "$ref": "#/$defs/term"
          }
        },
        "required": [
          "match",
          "registry_id",
          "term"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "registry_id": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "slug": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "slug_qualified": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "symbol": {
      "minLength": 1,
      "type": "string"
    },
    "term": {
      "minLength": 1,
      "type": "string"
    },
    "title": {
      "additionalProperties": false,
      "properties": {
        "en": {
          "minLength": 3,
          "type": "string"
        },
        "pt": {
          "minLength": 3,
          "type": "string"
        }
      },
      "type": "object"
    },
    "url": {
      "minLength": 1,
      "type": "string"
    }
  },
  "items": {
    "additionalProperties": false,
    "properties": {
      "description": {
        "$ref": "#/$defs/description"
      },
      "identity": {
        "$ref": "#/$defs/identity"
      },
      "ip_addresses": {
        "$ref": "#/$defs/ip_addresses"
      },
      "network_link": {
        "$ref": "#/$defs/network_link"
      },
      "refs": {
        "$ref": "#/$defs/refs"
      },
      "title": {
        "$ref": "#/$defs/title"
      }
    },
    "type": "object"
  },
  "type": "array"
}
