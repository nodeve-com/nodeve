{
  "$defs": {
    "archetype": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "broader": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "code": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{8}$",
      "type": "string"
    },
    "combined": {
      "type": "object"
    },
    "compose": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_]*$",
          "type": "string"
        },
        {
          "items": {
            "pattern": "^[a-z][a-z0-9_]*$",
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        }
      ]
    },
    "concept_settings": {
      "additionalProperties": false,
      "properties": {
        "compose": {
          "$ref": "#/$defs/compose"
        },
        "count": {
          "$ref": "#/$defs/count"
        },
        "is_array": {
          "$ref": "#/$defs/is_array"
        },
        "is_specification": {
          "$ref": "#/$defs/is_specification"
        },
        "map": {
          "$ref": "#/$defs/map"
        },
        "part": {
          "$ref": "#/$defs/part"
        },
        "repeated": {
          "$ref": "#/$defs/repeated"
        }
      },
      "type": "object"
    },
    "count": {
      "minimum": 1,
      "type": "integer"
    },
    "default": {
      "type": "object"
    },
    "description": {
      "additionalProperties": false,
      "properties": {
        "en": {
          "minLength": 3,
          "type": "string"
        },
        "pt": {
          "minLength": 3,
          "type": "string"
        }
      },
      "type": "object"
    },
    "feature_spec": {
      "additionalProperties": false,
      "properties": {
        "combined": {
          "$ref": "#/$defs/combined"
        },
        "default": {
          "$ref": "#/$defs/default"
        },
        "instances": {
          "$ref": "#/$defs/instances"
        },
        "ordinal": {
          "$ref": "#/$defs/ordinal"
        },
        "part": {
          "$ref": "#/$defs/part"
        },
        "part_id": {
          "$ref": "#/$defs/part_id"
        }
      },
      "type": "object"
    },
    "id": {
      "minLength": 1,
      "type": "string"
    },
    "identity": {
      "additionalProperties": false,
      "properties": {
        "archetype": {
          "$ref": "#/$defs/archetype"
        },
        "broader": {
          "$ref": "#/$defs/broader"
        },
        "code": {
          "$ref": "#/$defs/code"
        },
        "id": {
          "$ref": "#/$defs/id"
        },
        "iri_template": {
          "$ref": "#/$defs/iri_template"
        },
        "slug": {
          "$ref": "#/$defs/slug"
        },
        "slug_qualified": {
          "$ref": "#/$defs/slug_qualified"
        },
        "symbol": {
          "$ref": "#/$defs/symbol"
        },
        "url": {
          "$ref": "#/$defs/url"
        }
      },
      "type": "object"
    },
    "instances": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "iri_template": {
      "minLength": 1,
      "type": "string"
    },
    "is_array": {
      "type": "boolean"
    },
    "is_specification": {
      "type": "boolean"
    },
    "map": {
      "type": "boolean"
    },
    "match": {
      "enum": [
        "exact",
        "close",
        "broad",
        "narrow",
        "related"
      ]
    },
    "ordinal": {
      "exclusiveMinimum": 0,
      "type": "integer"
    },
    "part": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "part_id": {
      "pattern": "^(a|b|c|n|ab|bc|ca)$",
      "type": "string"
    },
    "refs": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "match": {
            "$ref": "#/$defs/match"
          },
          "registry_id": {
            "$ref": "#/$defs/registry_id"
          },
          "term": {
            "$ref": "#/$defs/term"
          }
        },
        "required": [
          "match",
          "registry_id",
          "term"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "registry_id": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "repeated": {
      "type": "boolean"
    },
    "slug": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "slug_qualified": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "symbol": {
      "minLength": 1,
      "type": "string"
    },
    "term": {
      "minLength": 1,
      "type": "string"
    },
    "title": {
      "additionalProperties": false,
      "properties": {
        "en": {
          "minLength": 3,
          "type": "string"
        },
        "pt": {
          "minLength": 3,
          "type": "string"
        }
      },
      "type": "object"
    },
    "url": {
      "minLength": 1,
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "concept_settings": {
      "$ref": "#/$defs/concept_settings"
    },
    "description": {
      "$ref": "#/$defs/description"
    },
    "feature_spec": {
      "$ref": "#/$defs/feature_spec"
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "refs": {
      "$ref": "#/$defs/refs"
    },
    "title": {
      "$ref": "#/$defs/title"
    }
  },
  "type": "object"
}
