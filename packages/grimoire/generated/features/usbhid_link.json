{
  "prop": {
    "expect": {
      "$ref": "../property/expect.json",
      "description": {
        "en": "The byte expected at offset in the frame (reject the frame otherwise). Named expect, not value — it's the byte the frame must carry, distinct from the many other value concepts."
      },
      "schema": {
        "maximum": 255,
        "minimum": 0,
        "type": "integer"
      },
      "title": {
        "en": "Expected byte"
      }
    },
    "firmware": {
      "$ref": "../property/firmware.json",
      "description": {
        "en": "Firmware-driven scale selection (offset + nibble + select); omit for a device whose scaling is fixed across firmware. Named firmware, not version: it's a decode-config selector, not a protocol-version value."
      },
      "schema": {
        "type": "object"
      },
      "title": {
        "en": "Firmware"
      }
    },
    "offset": {
      "$ref": "../property/offset.json",
      "description": {
        "en": "Zero-based byte offset into a request/response frame. The single place the key is defined — diag byte-fields, magic-byte checks and firmware-version bytes all compose it."
      },
      "schema": {
        "minimum": 0,
        "type": "integer"
      },
      "title": {
        "en": "Byte offset"
      }
    },
    "poll_command": {
      "$ref": "../property/poll_command.json",
      "description": {
        "en": "Request bytes written to fetch one diagnostics frame (M4-ATX: [0x81, 0x00])."
      },
      "schema": {
        "items": {
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "minItems": 1,
        "type": "array"
      },
      "title": {
        "en": "Poll command"
      }
    },
    "read_endpoint": {
      "$ref": "../property/read_endpoint.json",
      "description": {
        "en": "IN endpoint the response frame is read from (0x81 is IN 1). Authored as hex."
      },
      "schema": {
        "maximum": 255,
        "minimum": 0,
        "type": "integer"
      },
      "title": {
        "en": "Read endpoint"
      }
    },
    "response_length": {
      "$ref": "../property/response_length.json",
      "description": {
        "en": "How many bytes one response frame occupies (M4-ATX: 24)."
      },
      "schema": {
        "exclusiveMinimum": 0,
        "type": "integer"
      },
      "title": {
        "en": "Response length"
      }
    },
    "response_magic": {
      "$ref": "../property/response_magic.json",
      "description": {
        "en": "A leading sanity byte-check a device stamps on a valid frame/response, as { offset, expect }. Shared by the usbhid diag read and config exchange."
      },
      "schema": {
        "type": "object"
      },
      "title": {
        "en": "Response magic"
      }
    },
    "timeout_ms": {
      "$ref": "../property/timeout_ms.json",
      "description": {
        "en": "Per-transfer timeout in integer milliseconds."
      },
      "schema": {
        "exclusiveMinimum": 0,
        "type": "integer"
      },
      "title": {
        "en": "Timeout (ms)",
        "pt": "Timeout (ms)"
      }
    },
    "transfer": {
      "$ref": "../property/transfer.json",
      "description": {
        "en": "USB transfer type the exchange uses: interrupt endpoints (M4-ATX) or control pipe (HID Get/Set_Report)."
      },
      "schema": {
        "enum": [
          "interrupt",
          "control"
        ],
        "type": "string"
      },
      "title": {
        "en": "Transfer"
      }
    },
    "write_endpoint": {
      "$ref": "../property/write_endpoint.json",
      "description": {
        "en": "OUT endpoint the poll command is written to (8-bit address; high bit encodes direction — 0x01 is OUT 1). Authored as hex."
      },
      "schema": {
        "maximum": 255,
        "minimum": 0,
        "type": "integer"
      },
      "title": {
        "en": "Write endpoint"
      }
    }
  }
}
