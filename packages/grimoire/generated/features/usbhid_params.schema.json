{
  "$defs": {
    "access": {
      "enum": [
        "read",
        "write",
        "read_write"
      ],
      "type": "string"
    },
    "byte_order": {
      "enum": [
        "big_first",
        "little_first"
      ],
      "type": "string"
    },
    "decimals": {
      "minimum": 0,
      "type": "integer"
    },
    "index": {
      "maximum": 255,
      "minimum": 0,
      "type": "integer"
    },
    "name": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "scale": {
      "type": "number"
    },
    "scale_overrides": {
      "additionalProperties": {
        "type": "number"
      },
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "type": "object"
    },
    "sentinel": {
      "additionalProperties": false,
      "properties": {
        "meaning": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "type": "string"
        },
        "raw": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "type": {
      "type": "string"
    },
    "unit": {
      "minLength": 1,
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "access": {
      "$ref": "#/$defs/access"
    },
    "byte_order": {
      "$ref": "#/$defs/byte_order"
    },
    "decimals": {
      "$ref": "#/$defs/decimals"
    },
    "index": {
      "$ref": "#/$defs/index"
    },
    "name": {
      "$ref": "#/$defs/name"
    },
    "scale": {
      "$ref": "#/$defs/scale"
    },
    "scale_overrides": {
      "$ref": "#/$defs/scale_overrides"
    },
    "sentinel": {
      "$ref": "#/$defs/sentinel"
    },
    "type": {
      "$ref": "#/$defs/type"
    },
    "unit": {
      "$ref": "#/$defs/unit"
    }
  },
  "type": "object"
}
