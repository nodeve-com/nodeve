{
  "$defs": {
    "connect_timeout_ms": {
      "exclusiveMinimum": 0,
      "type": "integer"
    },
    "host": {
      "minLength": 1,
      "type": "string"
    },
    "pathname": {
      "minLength": 1,
      "type": "string"
    },
    "port": {
      "maximum": 65535,
      "minimum": 1,
      "type": "integer"
    },
    "reconnect_period_ms": {
      "exclusiveMinimum": 0,
      "type": "integer"
    },
    "version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "required": [
          "service_protocol"
        ]
      },
      "then": {
        "properties": {
          "transport_protocol": {
            "const": "tcp"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transport_protocol": {
            "const": "tcp"
          }
        },
        "required": [
          "transport_protocol"
        ]
      },
      "then": {
        "required": [
          "connect_timeout_ms",
          "reconnect_period_ms"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "transport_protocol": {
            "const": "udp"
          }
        },
        "required": [
          "transport_protocol"
        ]
      },
      "then": {
        "properties": {
          "connect_timeout_ms": false,
          "reconnect_period_ms": false
        }
      }
    }
  ],
  "properties": {
    "connect_timeout_ms": {
      "$ref": "#/$defs/connect_timeout_ms"
    },
    "host": {
      "$ref": "#/$defs/host"
    },
    "pathname": {
      "$ref": "#/$defs/pathname"
    },
    "port": {
      "$ref": "#/$defs/port"
    },
    "reconnect_period_ms": {
      "$ref": "#/$defs/reconnect_period_ms"
    },
    "service_protocol": {
      "enum": [
        "mqtt",
        "mqtts",
        "http",
        "https",
        "ws",
        "wss"
      ],
      "type": "string"
    },
    "transport_protocol": {
      "enum": [
        "tcp",
        "udp"
      ],
      "type": "string"
    },
    "version": {
      "$ref": "#/$defs/version"
    }
  },
  "type": "object"
}
