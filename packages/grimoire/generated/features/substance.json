{
  "description": {
    "en": "Chemical-substance facts — formula, global-warming potential, safety classification.",
    "pt": "Dados de uma substância química — fórmula, potencial de aquecimento global, classificação de segurança."
  },
  "prop": {
    "formula": {
      "$ref": "../property/formula.json",
      "description": {
        "en": "Chemical formula, code-like (C3H8). Not i18n."
      },
      "schema": {
        "minLength": 1,
        "type": "string"
      },
      "title": {
        "en": "Formula",
        "pt": "Fórmula"
      }
    },
    "gwp": {
      "$ref": "../property/gwp.json",
      "description": {
        "en": "Global warming potential, IPCC AR5 100-year basis (CO₂ = 1). Dimensionless."
      },
      "schema": {
        "minimum": 0,
        "type": "number"
      },
      "title": {
        "en": "GWP",
        "pt": "GWP"
      }
    },
    "safety_class": {
      "$ref": "../property/safety_class.json",
      "description": {
        "en": "ASHRAE Standard 34 safety classification — toxicity (A/B) × flammability (1 / 2L / 2 / 3); A3 = low-toxicity, highly flammable (propane)."
      },
      "refs": [
        {
          "match": "exact",
          "registry_id": "ashrae_34",
          "term": "safety_classification"
        }
      ],
      "schema": {
        "enum": [
          "A1",
          "A2L",
          "A2",
          "A3",
          "B1",
          "B2L",
          "B2",
          "B3"
        ],
        "type": "string"
      },
      "title": {
        "en": "Safety class",
        "pt": "Classe de segurança"
      }
    }
  },
  "title": {
    "en": "Substance",
    "pt": "Substância"
  }
}
