{
  "$defs": {
    "catalog_ref": {
      "minLength": 1,
      "type": "string"
    },
    "format": {
      "enum": [
        "grouped",
        "per_value"
      ],
      "type": "string"
    },
    "link": {
      "minLength": 1,
      "type": "string"
    },
    "publish": {
      "enum": [
        "changed",
        "always"
      ],
      "type": "string"
    },
    "slug": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "topic_prefix": {
      "minLength": 1,
      "type": "string"
    },
    "unit_id": {
      "maximum": 247,
      "minimum": 0,
      "type": "integer"
    },
    "update_interval_ms": {
      "exclusiveMinimum": 0,
      "type": "integer"
    }
  },
  "items": {
    "additionalProperties": false,
    "properties": {
      "catalog_ref": {
        "$ref": "#/$defs/catalog_ref"
      },
      "format": {
        "$ref": "#/$defs/format"
      },
      "link": {
        "$ref": "#/$defs/link"
      },
      "publish": {
        "$ref": "#/$defs/publish"
      },
      "slug": {
        "$ref": "#/$defs/slug"
      },
      "topic_prefix": {
        "$ref": "#/$defs/topic_prefix"
      },
      "unit_id": {
        "$ref": "#/$defs/unit_id"
      },
      "update_interval_ms": {
        "$ref": "#/$defs/update_interval_ms"
      }
    },
    "type": "object"
  },
  "type": "array"
}
