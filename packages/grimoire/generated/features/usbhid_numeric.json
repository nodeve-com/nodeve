{
  "prop": {
    "byte_order": {
      "$ref": "../property/byte_order.json",
      "description": {
        "en": "Byte order for multi-byte types; omit ⇒ big_first (the network/HID default). Ignored for single-byte types."
      },
      "schema": {
        "enum": [
          "big_first",
          "little_first"
        ],
        "type": "string"
      },
      "title": {
        "en": "Byte order",
        "pt": "Ordem de bytes"
      }
    },
    "scale_overrides": {
      "$ref": "../property/scale_overrides.json",
      "description": {
        "en": "Per-firmware-profile scale overrides, keyed by the profile a link firmware rule selects. When the resolved profile has an entry, it replaces `scale`; otherwise `scale` stands."
      },
      "schema": {
        "additionalProperties": {
          "type": "number"
        },
        "propertyNames": {
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "type": "object"
      },
      "title": {
        "en": "Scale overrides",
        "pt": "Escalas por firmware"
      }
    }
  }
}
