{
  "prop": {
    "dew_point": {
      "measurand": {
        "accumulation": "instantaneous",
        "si_unit": "K"
      },
      "refs": [
        {
          "match": "exact",
          "registry_id": "qudt_quantity_kind",
          "term": "DewPointTemperature"
        },
        {
          "match": "broad",
          "registry_id": "ha_device_class",
          "term": "temperature"
        }
      ],
      "schema": {
        "type": "number"
      },
      "title": {
        "en": "Dew point",
        "pt": "Ponto de orvalho"
      }
    },
    "relative_humidity": {
      "measurand": {
        "accumulation": "instantaneous",
        "si_unit": "%"
      },
      "refs": [
        {
          "match": "exact",
          "registry_id": "qudt_quantity_kind",
          "term": "RelativeHumidity"
        },
        {
          "match": "exact",
          "registry_id": "ha_device_class",
          "term": "humidity"
        }
      ],
      "schema": {
        "type": "number"
      },
      "title": {
        "en": "Relative humidity",
        "pt": "Humidade relativa"
      }
    },
    "temperature": {
      "measurand": {
        "accumulation": "instantaneous",
        "si_unit": "K"
      },
      "refs": [
        {
          "match": "exact",
          "registry_id": "qudt_quantity_kind",
          "term": "Temperature"
        },
        {
          "match": "exact",
          "registry_id": "ha_device_class",
          "term": "temperature"
        }
      ],
      "schema": {
        "type": "number"
      },
      "title": {
        "en": "Temperature",
        "pt": "Temperatura"
      }
