{
  "$defs": {
    "match": {
      "enum": [
        "exact",
        "close",
        "broad",
        "narrow",
        "related"
      ]
    },
    "registry_id": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    },
    "term": {
      "minLength": 1,
      "type": "string"
    }
  },
  "items": {
    "additionalProperties": false,
    "properties": {
      "match": {
        "$ref": "#/$defs/match"
      },
      "registry_id": {
        "$ref": "#/$defs/registry_id"
      },
      "term": {
        "$ref": "#/$defs/term"
      }
    },
    "required": [
      "match",
      "registry_id",
      "term"
    ],
    "type": "object"
  },
  "type": "array"
}
