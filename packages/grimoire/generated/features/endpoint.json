{
  "description": {
    "en": "One way to reach a node — a URL when a service_protocol scheme is set (rendered ${scheme}://${host}:${port}${pathname}), or a raw tcp/udp socket when it isn't (bare ${host}:${port}). Reachability comes from socket_address; dial policy from reconnect. Every field optional, falling back to shared/well-known defaults."
  },
  "prop": {
    "connect_timeout_ms": {
      "$ref": "../property/connect_timeout_ms.json",
      "description": {
        "en": "How long a connection attempt waits before giving up, integer milliseconds. Distinct from the per-transfer timeout_ms."
      },
      "schema": {
        "exclusiveMinimum": 0,
        "type": "integer"
      },
      "title": {
        "en": "Connect timeout (ms)",
        "pt": "Timeout de conexão (ms)"
      }
    },
    "host": {
      "$ref": "../property/host.json",
      "description": {
        "en": "Hostname or IP an endpoint is reached at (the remote address a dialer connects out to). No sensible default — deployment-specific, supplied downstream."
      },
      "schema": {
        "minLength": 1,
        "type": "string"
      },
      "title": {
        "en": "Host"
      }
    },
    "pathname": {
      "$ref": "../property/pathname.json",
      "description": {
        "en": "A slash-delimited path a resource is reached or published under (like URL.pathname): the URL path an endpoint serves on (WebSocket schemes use it, TCP omit it — bare / when absent), or the shared root a set of publishers nest their paths beneath (<pathname>/<slug>)."
      },
      "schema": {
        "minLength": 1,
        "type": "string"
      },
      "title": {
        "en": "Pathname"
      }
    },
    "port": {
      "$ref": "../property/port.json",
      "description": {
        "en": "TCP/UDP port number. Omit to fall back to the scheme's well-known default."
      },
      "schema": {
        "maximum": 65535,
        "minimum": 1,
        "type": "integer"
      },
      "title": {
        "en": "Port"
      }
    },
    "reconnect_period_ms": {
      "$ref": "../property/reconnect_period_ms.json",
      "description": {
        "en": "Delay before a dropped connection is retried, integer milliseconds."
      },
      "schema": {
        "exclusiveMinimum": 0,
        "type": "integer"
      },
      "title": {
        "en": "Reconnect period (ms)",
        "pt": "Período de reconexão (ms)"
      }
    },
    "service_protocol": {
      "schema": {
        "enum": [
          "mqtt",
          "mqtts",
          "http",
          "https",
          "ws",
          "wss"
        ],
        "type": "string"
      }
    },
    "transport_protocol": {
      "schema": {
        "enum": [
          "tcp",
          "udp"
        ],
        "type": "string"
      }
    },
    "version": {
      "$ref": "../property/version.json",
      "description": {
        "en": "Wire-protocol version an endpoint speaks (e.g. MQTT 5 vs 3.1.1). Omit to fall back to the scheme's default."
      },
      "schema": {
        "minLength": 1,
        "type": "string"
      },
      "title": {
        "en": "Protocol version"
      }
    }
  },
  "schema": {
    "allOf": [
      {
        "if": {
          "required": [
            "service_protocol"
          ]
        },
        "then": {
          "properties": {
            "transport_protocol": {
              "const": "tcp"
            }
          }
        }
      },
      {
        "if": {
          "properties": {
            "transport_protocol": {
              "const": "tcp"
            }
          },
          "required": [
            "transport_protocol"
          ]
        },
        "then": {
          "required": [
            "connect_timeout_ms",
            "reconnect_period_ms"
          ]
        }
      },
      {
        "if": {
          "properties": {
            "transport_protocol": {
              "const": "udp"
            }
          },
          "required": [
            "transport_protocol"
          ]
        },
        "then": {
          "properties": {
            "connect_timeout_ms": false,
            "reconnect_period_ms": false
          }
        }
      }
    ]
  },
  "title": {
    "en": "Endpoint"
  }
}
