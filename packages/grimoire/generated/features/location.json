{
  "description": {
    "en": "A site's geographic point (WGS 84 latitude / longitude / altitude above sea level).",
    "pt": "O ponto geográfico de um site (latitude / longitude / altitude acima do nível do mar, WGS 84)."
  },
  "prop": {
    "altitude": {
      "measurand": {
        "accumulation": "instantaneous",
        "si_unit": "m"
      },
      "refs": [
        {
          "match": "exact",
          "registry_id": "qudt_quantity_kind",
          "term": "Altitude"
        },
        {
          "match": "exact",
          "registry_id": "wgs84_geo",
          "term": "alt"
        }
      ],
      "schema": {
        "type": "number"
      },
      "title": {
        "en": "Altitude",
        "pt": "Altitude"
      }
    },
    "latitude": {
      "$ref": "../property/latitude.json",
      "measurand": {
        "accumulation": "instantaneous",
        "si_unit": "°"
      },
      "refs": [
        {
          "match": "exact",
          "registry_id": "wgs84_geo",
          "term": "lat"
        },
        {
          "match": "broad",
          "registry_id": "qudt_quantity_kind",
          "term": "Angle"
        }
      ],
      "schema": {
        "maximum": 90,
        "minimum": -90,
        "required": true,
        "type": "number"
      },
      "title": {
        "en": "Latitude",
        "pt": "Latitude"
      }
    },
    "longitude": {
      "$ref": "../property/longitude.json",
      "measurand": {
        "accumulation": "instantaneous",
        "si_unit": "°"
      },
      "refs": [
        {
          "match": "exact",
          "registry_id": "wgs84_geo",
          "term": "long"
        },
        {
          "match": "broad",
          "registry_id": "qudt_quantity_kind",
          "term": "Angle"
        }
      ],
      "schema": {
        "maximum": 180,
        "minimum": -180,
        "required": true,
        "type": "number"
      },
      "title": {
        "en": "Longitude",
        "pt": "Longitude"
      }
    }
  },
  "title": {
    "en": "Location",
    "pt": "Local"
  }
}
