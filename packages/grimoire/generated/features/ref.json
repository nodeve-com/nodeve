{
  "prop": {
    "match": {
      "$ref": "../property/match.json",
      "schema": {
        "enum": [
          "exact",
          "close",
          "broad",
          "narrow",
          "related"
        ],
        "required": true
      }
    },
    "registry_id": {
      "$ref": "../property/registry_id.json",
      "column": {
        "references": "registry"
      },
      "description": {
        "en": "Slug of the registry catalog entry whose id-space the crosswalk term is drawn from."
      },
      "schema": {
        "pattern": "^[a-z][a-z0-9_]*$",
        "required": true,
        "type": "string"
      },
      "title": {
        "en": "Registry",
        "pt": "Registro"
      }
    },
    "term": {
      "$ref": "../property/term.json",
      "description": {
        "en": "The identifier of an entry WITHIN a registry — the code that, resolved through the registry's IRI template, names the external concept a crosswalk ref points at (e.g. Temperature in qudt_quantity_kind, 2.3 in vim)."
      },
      "schema": {
        "minLength": 1,
        "required": true,
        "type": "string"
      },
      "title": {
        "en": "Term",
        "pt": "Termo"
      }
    }
  },
  "title": {
    "en": "Crosswalk reference",
    "pt": "Referência de crosswalk"
  }
}
