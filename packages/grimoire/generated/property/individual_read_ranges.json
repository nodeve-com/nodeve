{
  "description": {
    "en": "Inclusive [lo, hi] address ranges to read one register at a time, each with a human note."
  },
  "schema": {
    "items": {
      "additionalProperties": false,
      "properties": {
        "note": {
          "minLength": 1,
          "type": "string"
        },
        "range": {
          "items": {
            "maximum": 65535,
            "minimum": 0,
            "type": "integer"
          },
          "maxItems": 2,
          "minItems": 2,
          "type": "array"
        }
      },
      "required": [
        "range",
        "note"
      ],
      "type": "object"
    },
    "type": "array"
  },
  "title": {
    "en": "Individual read ranges"
  }
}
