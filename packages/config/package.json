{
  "name": "@nodeve/config",
  "version": "0.2.0",
  "description": "Shared TypeScript, Prettier, and ESLint configuration for nodeve and sister projects.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodeve-com/nodeve.git",
    "directory": "packages/config"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "tsconfig.json",
    "prettier",
    "eslint"
  ],
  "exports": {
    "./tsconfig": "./tsconfig.json",
    "./prettier": "./prettier/index.js",
    "./prettier/base": "./prettier/base.js",
    "./eslint": "./eslint/index.js",
    "./eslint/base": "./eslint/base.js"
  },
  "peerDependencies": {
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "globals": "catalog:",
